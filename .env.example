# quorum secrets -- copy to .env and fill in the providers you actually use.
# Never commit .env. Only the providers referenced by your council need a key;
# a local Ollama needs none, and the offline "mock" provider needs none.

# OpenRouter (one key unlocks OpenAI, Anthropic, Google, xAI, Meta, ... models)
QUORUM_OPENROUTER_KEY=

# Direct providers (optional -- only if you reference them in config.yaml)
QUORUM_OPENAI_KEY=
QUORUM_GROQ_KEY=
